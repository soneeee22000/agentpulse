PORT=8080
HOST=0.0.0.0
CORS_ORIGIN=*

# Event bus driver: "memory" (default, offline) or "pubsub" (GCP).
BUS_DRIVER=memory

# Auto-start the synthetic traffic simulator on boot.
SIM_AUTOSTART=true

# Only used when BUS_DRIVER=pubsub (standard Google ADC credentials apply).
GCP_PROJECT_ID=
PUBSUB_TOPIC=agentpulse-events
PUBSUB_SUBSCRIPTION=agentpulse-events-sub
