# ── Backend (apps/api) ───────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
CORS_ORIGIN=*

# Event bus driver: "memory" (default, fully offline) or "pubsub" (GCP).
BUS_DRIVER=memory

# Start the synthetic traffic simulator automatically on boot so the
# dashboard is alive with zero clicks. Set to "false" to start it manually.
SIM_AUTOSTART=true

# ── GCP Pub/Sub (only when BUS_DRIVER=pubsub) ────────────────────────
# Standard Google credentials apply (GOOGLE_APPLICATION_CREDENTIALS, ADC).
GCP_PROJECT_ID=
PUBSUB_TOPIC=agentpulse-events
PUBSUB_SUBSCRIPTION=agentpulse-events-sub

# ── Frontend (apps/web) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
